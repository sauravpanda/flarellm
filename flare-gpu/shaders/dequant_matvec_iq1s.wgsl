// Fused IQ1_S dequantize + batched matrix-vector multiply on GPU.
//
// IQ1_S block layout (50 bytes per block, 256 weights — GGUF type 19):
//   bytes 0-1:    d        — f16 LE super-block scale
//   bytes 2-33:   qs[32]   — low 8 bits of 11-bit grid index (8 groups × 4 per group)
//   bytes 34-49:  qh[8]    — uint16 LE per-group metadata:
//                            bits 2:0  = high 3 bits of grid index for l=0
//                            bits 5:3  = high 3 bits of grid index for l=1
//                            bits 8:6  = high 3 bits of grid index for l=2
//                            bits 11:9 = high 3 bits of grid index for l=3
//                            bits 14:12 = scale factor s ∈ [0, 7]
//                            bit  15    = delta sign (1 → negative)
//
// For each ib32 ∈ [0, 7]:
//   qh_val = qh[ib32]                               — uint16
//   dl     = d * (2 * ((qh_val >> 12) & 7) + 1)    — group scale
//   delta  = qh_val & 0x8000 ? -0.125 : +0.125     — group delta offset
//   For l ∈ [0, 3]:
//     grid_idx = qs[4*ib32 + l] | (((qh_val >> (3*l)) & 7) << 8)  — 11-bit index
//     For j ∈ [0, 7]:
//       signed_byte = int8(iq1s_grid[grid_idx][j])  — value ∈ {-1, 0, +1}
//       weight = dl * (f32(signed_byte) + delta)
//
// 50 bytes is not u32-aligned. Rust caller pads to 52 bytes before upload.
//
// Bindings:
//   binding 0: raw    — packed IQ1_S weight data (u32-padded)
//   binding 1: vec    — f32 input vector [batch_size * num_blocks_per_row * 256]
//   binding 2: output — f32 result       [batch_size * num_rows]
//   binding 3: params — uniform

@group(0) @binding(0) var<storage, read> raw: array<u32>;
@group(0) @binding(1) var<storage, read> vec: array<f32>;
@group(0) @binding(2) var<storage, read_write> output: array<f32>;

struct Params {
    num_rows:           u32,
    num_blocks_per_row: u32,
    batch_size:         u32,
}
@group(0) @binding(3) var<uniform> params: Params;

var<workgroup> partials: array<f32, 64>;

