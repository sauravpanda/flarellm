/// Extract one byte at the given absolute byte offset from the u32 storage array.
fn read_byte(byte_offset: u32) -> u32 {
    return (raw[byte_offset / 4u] >> ((byte_offset % 4u) * 8u)) & 0xFFu;
}

/// Read a u16 LE value at the given absolute byte offset.
fn read_u16(byte_offset: u32) -> u32 {
    return read_byte(byte_offset) | (read_byte(byte_offset + 1u) << 8u);
}

/// Read byte j of iq1s_grid[idx] split as (LO, HI) u32 halves.
/// j ∈ [0, 3] → from LO half; j ∈ [4, 7] → from HI half.
fn grid1s_byte(idx: u32, j: u32) -> u32 {
    if j < 4u {
        return (IQ1S_GRID_LO[idx] >> (j * 8u)) & 0xFFu;
    } else {
        return (IQ1S_GRID_HI[idx] >> ((j - 4u) * 8u)) & 0xFFu;
    }
}

/// Sign-extend an 8-bit value (stored as u32 in range [0, 255]) to a signed f32.
/// Values 0xFF → -1.0, 0x00 → 0.0, 0x01 → +1.0 (IQ1_S grid uses {-1, 0, +1}).
fn byte_to_signed_f32(b: u32) -> f32 {
    return f32(bitcast<i32>(b << 24u) >> 24);
}

@compute @workgroup_size(64)
fn dequant_matvec_iq1s(
    @builtin(local_invocation_id) lid: vec3<u32>,
    @builtin(workgroup_id)        wid: vec3<u32>,
) {
    let row   = wid.x;
    let batch = wid.y;
    let tid   = lid.x;

    if row >= params.num_rows { return; }

    var acc = 0.0f;

    // 52 bytes per block (50 padded to u32 multiple). Threads stride across blocks.
    for (var b = tid; b < params.num_blocks_per_row; b = b + 64u) {
        if b >= params.num_blocks_per_row { break; }

        // Byte offset of this block (52 bytes per padded block).
        let bb = (row * params.num_blocks_per_row + b) * 52u;

        let d_bits = read_u16(bb);
        let d = f16_to_f32(d_bits);

        let vec_base = (batch * params.num_blocks_per_row + b) * 256u;

        // Process 8 groups of 32 weights.
        for (var ib32 = 0u; ib32 < 8u; ib32 = ib32 + 1u) {
            // qh[ib32] is a uint16 at byte offset 34 + 2*ib32 within the block.
            let qh_val = read_u16(bb + 34u + ib32 * 2u);

            // Group scale: dl = d * (2 * s + 1) where s = bits 14:12 of qh_val.
            let s  = (qh_val >> 12u) & 7u;
            let dl = d * f32(2u * s + 1u);

            // Group delta offset: -0.125 if bit 15 is set, else +0.125.
            let delta = select(0.125, -0.125, (qh_val & 0x8000u) != 0u);

            let vec_ib32_base = vec_base + ib32 * 32u;

            for (var l = 0u; l < 4u; l = l + 1u) {
                // 11-bit grid index: low 8 bits from qs, high 3 bits from qh.
                let qs_lo    = read_byte(bb + 2u + ib32 * 4u + l);
                let grid_hi  = (qh_val >> (3u * l)) & 7u;
                let grid_idx = qs_lo | (grid_hi << 8u);

                let vec_sub = vec_ib32_base + l * 8u;

                for (var j = 0u; j < 8u; j = j + 1u) {
                    let gb_u   = grid1s_byte(grid_idx, j);
                    let gb     = byte_to_signed_f32(gb_u);
                    let weight = dl * (gb + delta);
                    acc = acc + weight * vec[vec_sub + j];
                }
            }
        }
    }

    // Tree reduction in workgroup.
    partials[tid] = acc;
    workgroupBarrier();
    for (var stride = 32u; stride >= 1u; stride = stride >> 1u) {
        if tid < stride {
            partials[tid] = partials[tid] + partials[tid + stride];
        }
        workgroupBarrier();
    }
    if tid == 0u {
        output[batch * params.num_rows + row] = partials[0];
    }
}

/// Convert a 16-bit IEEE 754 half-precision float (stored as u32) to f32.
fn f16_to_f32(h: u32) -> f32 {
    let sign     = (h & 0x8000u) << 16u;
    let exp      = (h & 0x7C00u) >> 10u;
    let mantissa = (h & 0x03FFu);
    if exp == 0u {
        return bitcast<f32>(sign);
    }
    if exp == 31u {
        return bitcast<f32>(sign | 0x7F800000u | (mantissa << 13u));
    }
    let f_exp  = (exp + 112u) << 23u;
    let f_mant = mantissa << 13u;
    return bitcast<f32>(sign | f_exp | f_mant);
}
