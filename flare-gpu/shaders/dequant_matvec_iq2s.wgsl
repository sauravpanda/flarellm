// Fused IQ2_S dequantize + batched matrix-vector multiply on GPU.
//
// IQ2_S block layout (82 bytes per block, 256 weights — GGUF type 21):
//   bytes 0-1:    d        — f16 LE super-block scale
//   bytes 2-33:   qs_lo[32] — low 8 bits of 10-bit grid index (8 groups × 4 per group)
//   bytes 34-65:  signs[32] — sign masks (8 groups × 4 bytes, 8 sign bits per byte)
//   bytes 66-73:  qh[8]     — high 2 bits of 10-bit grid index (4 pairs packed per byte)
//   bytes 74-81:  scales[8] — per-ib32 scale: lo nibble for l=0,1; hi nibble for l=2,3
//
// For each ib32 ∈ [0, 7]:
//   scale = scales[ib32]
//   db0 = d * (0.5 + f32(scale & 0xF)) * 0.25     (for l = 0, 1)
//   db1 = d * (0.5 + f32(scale >> 4))  * 0.25     (for l = 2, 3)
//   qh_byte = qh[ib32]
//   For l ∈ [0, 3]:
//     dl = db0 if l < 2 else db1
//     qs_lo = qs_lo[4*ib32 + l]                   — low 8 bits of grid index
//     grid_hi = (qh_byte >> (2*l)) & 3             — high 2 bits
//     grid_idx = qs_lo | (grid_hi << 8)            — 10-bit index into IQ2S_GRID[1024]
//     signs_byte = signs[4*ib32 + l]               — 8 sign bits
//     For j ∈ [0, 7]:
//       weight = dl * f32(grid_byte(grid_idx, j)) * sign(signs_byte, j)
//
// 82 bytes is not u32-aligned. Rust caller pads to 84 bytes before upload.
//
// Bindings:
//   binding 0: raw    — packed IQ2_S weight data (u32-padded)
//   binding 1: vec    — f32 input vector [batch_size * num_blocks_per_row * 256]
//   binding 2: output — f32 result       [batch_size * num_rows]
//   binding 3: params — uniform

@group(0) @binding(0) var<storage, read> raw: array<u32>;
@group(0) @binding(1) var<storage, read> vec: array<f32>;
@group(0) @binding(2) var<storage, read_write> output: array<f32>;

struct Params {
    num_rows:           u32,
    num_blocks_per_row: u32,
    batch_size:         u32,
}
@group(0) @binding(3) var<uniform> params: Params;

var<workgroup> partials: array<f32, 64>;

